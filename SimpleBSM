# Define BSM paramaters
@jax.jit
def bsm_historical_hyper_fast(S, K, T_t,T_c, r, q, vol):
    
    v_sqT = vol * jnp.sqrt(jnp.maximum(T_t, 1e-7))
    
    # Drift uses Calendar Time
    r_drift = r * T_c
    q_drift = q * T_c
    
    disc_S = jnp.exp(-q_drift)
    disc_K = jnp.exp(-r_drift)
    
    S_adj = S * disc_S
    K_adj = K * disc_K

    drift_term = r_drift - q_drift
    vol_term   = 0.5 * (v_sqT**2)
    
    d1 = (jnp.log(S / K) + drift_term + vol_term) / v_sqT
    d2 = d1 - v_sqT

    Nd1 = ndtr(d1)
    Nd2 = ndtr(d2)

    Call_p = (S_adj * Nd1) - (K_adj * Nd2)
    Put_p = Call_p - S_adj + K_adj 

    return Call_p, Put_p

fBSM = jit(vmap(bsm_historical_hyper_fast, in_axes=(0, None, None, None, 0, None, None)))

