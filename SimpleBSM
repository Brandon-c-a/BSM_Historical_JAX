# Define Returns & Volatility
@jax.jit
def process_market_data(hourly_prices, rates, pT, pC):
   
    y_ln = jnp.log(hourly_prices.astype(jnp.float64))
    risk_free_period = rates[:-1] / pC
    
    # 1. Log Returns
    log_returns = jnp.diff(y_ln)
    Excess_returns = log_returns - risk_free_period
    
    # 3. Volatility 
    time_scale = jnp.sqrt(pT)
    
    vol_annual = jnp.std(log_returns) * time_scale
    Ex_vol_annual = jnp.std(Excess_returns) * time_scale
    
    return log_returns.size, log_returns, Excess_returns, vol_annual, Ex_vol_annual

